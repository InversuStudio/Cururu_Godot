nome_display = "Caju"
sprite_display = ExtResource("2_rjhf6")
desc_item = "O caju é nativo do Brasil, amplamente encontrado nas regiões litorâneas e muito utilizado por povos indígenas desde antes da colonização. Seu pseudofruto é carnudo, suculento e varia entre tons de amarelo e vermelho, enquanto o verdadeiro fruto é a castanha localizada em sua extremidade. Além disso, a palavra \"caju\" tem origem no termo indígena “acaiu”, que pode ser interpretado como “amarelo”."
